{
	"name": "pi-apply-patch",
	"version": "0.1.1",
	"description": "Codex-style apply_patch tool extension for the pi coding agent. Registers a freeform grammar patch tool for OpenAI GPT models and applies patches with Node path resolution.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/pi-apply-patch",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/pi-apply-patch.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/pi-apply-patch/issues"
	},
	"keywords": [
		"pi",
		"pi-mono",
		"pi-coding-agent",
		"pi-extension",
		"coding-agent",
		"apply-patch",
		"codex",
		"openai",
		"gpt",
		"typescript"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsgo --noEmit && biome check ."
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/node": "^25.6.2",
		"@typescript/native-preview": "^7.0.0-dev.20260507.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"diff": "^9.0.0"
	}
}
